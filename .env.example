# Frontend (Lovable env vars em produção; arquivo .env em dev local)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-your-anon-key
VITE_SUPABASE_PROJECT_ID=replace-with-your-project-id

# ─────────────────────────────────────────────────────────────
# NÃO COLOCAR AS CHAVES ABAIXO NESTE ARQUIVO — vivem em outros lugares
# ─────────────────────────────────────────────────────────────

# Supabase Edge Functions
# Configurar em: Supabase Dashboard → Project Settings → Edge Functions → Secrets
#   SUPABASE_SERVICE_ROLE_KEY
#   OPENROUTER_API_KEY
#   GROQ_API_KEY
#   META_APP_ID
#   META_APP_SECRET
#   META_VERIFY_TOKEN
#   ASAAS_API_KEY
#   ASAAS_WEBHOOK_TOKEN
#   ELEVENLABS_API_KEY
#   LIVEKIT_API_KEY
#   LIVEKIT_API_SECRET
#   TELNYX_API_KEY
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID

# Runtime DeerFlow
# Configurar em: Railway → aikortex-flow → Variables
#   OPENROUTER_API_KEY
#   SUPABASE_SERVICE_ROLE
